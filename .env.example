# AI自动写小说系统环境变量配置示例

# ===========================================
# 基础配置
# ===========================================

# 应用环境
APP_ENV=development
DEBUG=true

# 日志级别
LOG_LEVEL=INFO

# ===========================================
# 数据库配置
# ===========================================

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_novel
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# 数据库连接URL
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_novel

# ===========================================
# Redis配置
# ===========================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis连接URL
REDIS_URL=redis://redis:6379/0

# ===========================================
# AI模型配置
# ===========================================

# 本地模型配置
LOCAL_MODEL_PATH=/app/models/local
LOCAL_MODEL_NAME=qwen3.6
LOCAL_MODEL_CONTEXT_SIZE=4096
LOCAL_MODEL_GPU_LAYERS=0

# OpenAI配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4

# Claude配置
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_API_BASE=https://api.anthropic.com
CLAUDE_DEFAULT_MODEL=claude-3-sonnet-20240229

# ===========================================
# 服务配置
# ===========================================

# AI模型服务
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
AI_SERVICE_WORKERS=1

# 小说生成服务
NOVEL_SERVICE_HOST=0.0.0.0
NOVEL_SERVICE_PORT=8002
NOVEL_SERVICE_WORKERS=1

# 前端服务
FRONTEND_PORT=3000

# ===========================================
# 安全配置
# ===========================================

# JWT配置
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# CORS配置
CORS_ORIGINS=["http://localhost:3000", "http://localhost:80", "https://yourdomain.com"]

# ===========================================
# 支付配置
# ===========================================

# 支付宝
ALIPAY_APP_ID=your_alipay_appid
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key

# 微信支付
WECHAT_PAY_APPID=your_wechat_appid
WECHAT_PAY_MCHID=your_wechat_mchid
WECHAT_PAY_API_KEY=your_wechat_api_key

# ===========================================
# 邮件配置
# ===========================================

# SMTP配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@example.com

# ===========================================
# 文件存储配置
# ===========================================

# 本地存储
LOCAL_STORAGE_PATH=/app/storage

# 云存储（可选）
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your_bucket_name

# ===========================================
# 监控配置
# ===========================================

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ENABLED=true
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin

# ===========================================
# 第三方服务配置
# ===========================================

# 短信服务（可选）
# SMS_PROVIDER=aliyun
# SMS_ACCESS_KEY=your_sms_access_key
# SMS_SECRET_KEY=your_sms_secret_key
# SMS_SIGN_NAME=your_sms_sign_name
# SMS_TEMPLATE_CODE=your_sms_template_code

# 对象存储（可选）
# OSS_PROVIDER=aliyun
# OSS_ACCESS_KEY=your_oss_access_key
# OSS_SECRET_KEY=your_oss_secret_key
# OSS_BUCKET=your_oss_bucket
# OSS_ENDPOINT=your_oss_endpoint

# ===========================================
# 开发配置
# ===========================================

# 热重载
HOT_RELOAD=true

# 调试端口
DEBUG_PORT=5678

# 测试数据库
TEST_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_novel_test

# ===========================================
# 生产环境配置（覆盖上述配置）
# ===========================================

# 生产环境时取消注释并修改以下配置
# APP_ENV=production
# DEBUG=false
# LOG_LEVEL=WARNING
# SECRET_KEY=your-strong-secret-key-for-production
# CORS_ORIGINS=["https://yourdomain.com"]
# POSTGRES_PASSWORD=your-strong-database-password
# REDIS_PASSWORD=your-strong-redis-password